{
  "name": "aws-profile-manager",
  "version": "1.2.3",
  "description": "AWS Profile Manager - SAML credential management for Windows",
  "main": "dist/main/main.js",
  "type": "module",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MichaelGermino/AWSProfileManager.git"
  },
  "scripts": {
    "dev": "npm run build:main && concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "npm run build:main && vite build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/write-cjs-markers.mjs",
    "preview": "vite preview",
    "rebuild-native": "electron-rebuild --only=keytar",
    "pack": "npm run rebuild-native && npm run build && electron-builder --dir",
    "dist": "npm run rebuild-native && npm run build && electron-builder",
    "release": "npm run rebuild-native && npm run build && electron-builder --publish always",
    "postinstall": "electron-rebuild --only=keytar"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "^3.700.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.7.7",
    "axios-cookiejar-support": "^5.0.0",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "ini": "^5.0.0",
    "keytar": "^7.9.0",
    "node-pty": "^1.1.0",
    "tough-cookie": "^4.1.3",
    "uuid": "^10.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/ini": "^4.1.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/tough-cookie": "^4.0.5",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^7.3.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.awsprofilemanager.app",
    "productName": "AWS Profile Manager",
    "directories": {
      "output": "release"
    },
    "npmRebuild": false,
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "MichaelGermino",
      "repo": "AWSProfileManager"
    }
  }
}
